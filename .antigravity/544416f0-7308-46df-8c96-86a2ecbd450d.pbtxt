      replacement_content: "import { QuizQuestion } from \"../types\";\n\nexport const FRANCAIS_QUESTIONS: QuizQuestion[] = [\n  {\n    id: \"fr_1\",\n    question: \"Quelle est l\'orthographe correcte dans cette phrase : \302\253 Ils ont oubli\303\251 ____ cl\303\251s sur la table. \302\273\",\n    options: [\"ses\", \"ces\", \"leurs\", \"leur\"],\n    correctAnswer: \"leurs\",\n    explanation: \"\302\253 Leurs \302\273 s\'accorde au pluriel avec le nom \302\253 cl\303\251s \302\273. C\'est un d\303\251terminant possessif pluriel.\"\n  },\n  {\n    id: \"fr_2\",\n    question: \"Accordez correctement le participe pass\303\251 : \302\253 Les pommes que j\'ai ____ sont d\303\251licieuses. \302\273 (manger)\",\n    options: [\"mang\303\251\", \"mang\303\251s\", \"mang\303\251e\", \"mang\303\251es\"],\n    correctAnswer: \"mang\303\251es\",\n    explanation: \"Le compl\303\251ment d\'objet direct \302\253 que \302\273 (mis pour les pommes, f\303\251minin pluriel) est plac\303\251 avant le verbe conjugu\303\251 avec avoir. On l\'accorde donc.\"\n  },\n  {\n    id: \"fr_3\",\n    question: \"Quel homophone convient ici ? \302\253 Il ____ bien compris sa le\303\247on d\'\303\251veil d\'hier ____ Waimes. \302\273\",\n    options: [\"a / \303\240\", \"\303\240 / a\", \"as / \303\240\", \"a / a\"],\n    correctAnswer: \"a / \303\240\",\n    explanation: \"\302\253 a \302\273 est le verbe avoir conjugu\303\251 (on peut dire \'avait\'). \302\253 \303\240 \302\273 est la pr\303\251position d\303\251signant le lieu (on ne peut pas dire \'avait Waimes\').\"\n  },\n  {\n    id: \"fr_4\",\n    question: \"Trouvez le synonyme du mot \302\253 \303\251ph\303\251m\303\250re \302\273 :\",\n    options: [\"\303\211ternel\", \"Tr\303\250s rapide\", \"Qui dure peu de temps\", \"Brillant\"],\n    correctAnswer: \"Qui dure peu de temps\",\n    explanation: \"Quelque chose d\'\303\251ph\303\251m\303\250re a une dur\303\251e de vie tr\303\250s courte (comme le papillon \303\251ph\303\251m\303\250re).\"\n  },\n  {\n    id: \"fr_5\",\n    question: \"Quelle figure de style utilise une exag\303\251ration ? \302\253 Je meurs de faim ! \302\273\",\n    options: [\"Une m\303\251taphore\", \"Une hyperbole\", \"Une comparaison\", \"Une personnification\"],\n    correctAnswer: \"Une hyperbole\",\n    explanation: \"L\'hyperbole consiste \303\240 exag\303\251rer une expression pour frapper les esprits.\"\n  }\n];\n\nexport const EVEIL_QUESTIONS: QuizQuestion[] = [\n  {\n    id: \"ev_1\",\n    question: \"Dans quelle province belge se situe la commune de Waimes ?\",\n    options: [\"Province de Li\303\250ge\", \"Province de Luxembourg\", \"Province de Namur\", \"Province du Hainaut\"],\n    correctAnswer: \"Province de Li\303\250ge\",\n    explanation: \"Waimes se trouve dans la province de Li\303\250ge, dans la r\303\251gion des Cantons de l\'Est.\"\n  },\n  {\n    id: \"ev_2\",\n    question: \"Quelle est la capitale officielle de la Belgique ?\",\n    options: [\"Anvers\", \"Namur\", \"Bruxelles\", \"Li\303\250ge\"],\n    correctAnswer: \"Bruxelles\",\n    explanation: \"Bruxelles est la capitale nationale de la Belgique et le si\303\250ge d\'institutions europ\303\251ennes majeures.\"\n  },\n  {\n    id: \"ev_3\",\n    question: \"\303\200 quel grand fleuve d\'Europe se rattache l\'Ourthe, qui coule en Wallonie ?\",\n    options: [\"La Seine\", \"La Meuse\", \"Le Rhin\", \"L\'Escaut\"],\n    correctAnswer: \"La Meuse\",\n    explanation: \"L\'Ourthe est un affluent colat\303\251ral important de la Meuse, qu\'elle rejoint \303\240 Li\303\250ge.\"\n  },\n  {\n    id: \"ev_4\",\n    question: \"Comment appelle-t-on le passage de l\'eau liquide \303\240 l\'\303\251tat de vapeur sous l\'effet de la chaleur ?\",\n    options: [\"La condensation\", \"La fusion\", \"L\'\303\251vaporation\", \"La solidification\"],\n    correctAnswer: \"L\'\303\251vaporation\",\n    explanation: \"L\'\303\251vaporation est le passage lent de l\'\303\251tat liquide \303\240 l\'\303\251tat gazeux, constitutif du cycle de l\'eau.\"\n  },\n  {\n    id: \"ev_5\",\n    question: \"Quelle est la dur\303\251e moyenne de la r\303\251volution de la Terre autour de notre Soleil ?\",\n    options: [\"24 heures\", \"28 jours\", \"365 jours et 6 heures\", \"12 mois pile\"],\n    correctAnswer: \"365 jours et 6 heures\",\n    explanation: \"La Terre met 365,25 jours \303\240 faire le tour du Soleil, ce qui explique l\'ajout d\'une journ\303\251e bissextile tous les 4 ans.\"\n  }\n];\n\nexport const JEUX_WORDS = [\n  { word: \"FRACTION\", hint: \"Partie d\'un tout, avec un num\303\251rateur et un d\303\251nominateur.\" },\n  { word: \"CONJUGAISON\", hint: \"La liste des formes vari\303\251es que prend un verbe selon la personne.\" },\n  { word: \"GEOGRAPHIE\", hint: \"L\'\303\251tude de la Terre, des pays, des rivi\303\250res et des cartes.\" },\n  { word: \"HISTOIRE\", hint: \"Le r\303\251cit des grands \303\251v\303\251nements du pass\303\251 humain.\" },\n  { word: \"ORTHOGRAPHE\", hint: \"L\'art d\'\303\251crire correctement les mots de la langue fran\303\247aise.\" },\n  { word: \"BELGIQUE\", hint: \"Notre beau pays divis\303\251 en R\303\251gions et Communaut\303\251s !\" },\n  { word: \"SCIENCES\", hint: \"La m\303\251thode pour observer, exp\303\251rimenter et comprendre l\'Univers.\" },\n  { word: \"PROVENCE\", hint: \"Oups, ce n\'est pas fran\303\247ais ! En Belgique on dit Province.\" }\n];\n"
